# AI Documind RAG System Environment Variables
# Copy this file to .env and fill in your actual API keys

# ===== LLM PROVIDER API KEYS =====
# At least one provider key is required

# Groq API Configuration (Fast, free tier available)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Configuration (Access to many models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Configuration (GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Configuration (stored for compatibility)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama API Configuration (Local models, usually no key required)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ===== PROVIDER PRIORITY =====
# Comma-separated list of providers to try in order
# Options: groq, openrouter, openai, gemini, ollama, anthropic
# Default: groq,openrouter,openai,gemini,ollama
PROVIDER_PRIORITY=groq,openrouter,openai,gemini,ollama

# ===== MODEL OVERRIDES (optional) =====
# Change default models without editing code
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_MODEL=llama3.1:8b

# ===== EMBEDDING MODEL =====
# Model for document embeddings (sentence-transformers)
# Default: sentence-transformers/all-MiniLM-L6-v2
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== CHUNKING CONFIGURATION =====
# Document chunking for retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4

# ===== VECTOR DATABASE (FAISS) =====
# Persist FAISS index between sessions
PERSIST_FAISS=true
FAISS_PERSIST_DIR=faiss_index

# ===== DATABASE CONFIGURATION =====
# SQLite database for conversation history
HISTORY_DB_PATH=conversation_history.db

# ===== API CONFIGURATION =====
# Backend API base URL (for frontend/app_api.py)
API_BASE_URL=http://localhost:8000

# ===== OPTIONAL: HUGGINGFACE TOKEN =====
# Required only for private/gated models
# HF_API_TOKEN=your_huggingface_token_here
